{
  "name": "@dudousxd/nestjs-durable-transport-db",
  "version": "0.1.1",
  "description": "Database (SQL) Transport for nestjs-durable — DBOS-style: dispatch remote steps as rows in the durable DB, no broker",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/transport-db"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-durable-core": ">=0.1.0 <1.0.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "@testcontainers/postgresql": "10.18.0",
    "mysql2": "3.11.5",
    "pg": "8.13.1",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.30",
    "typescript": "5.9.3",
    "zod": "3.25.76",
    "tsup": "8.3.5"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
