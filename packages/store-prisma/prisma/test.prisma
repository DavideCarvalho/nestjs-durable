// Self-contained schema used only to generate a client + push a SQLite DB for the adapter tests.
// The models mirror prisma/schema.prisma (the snippet users copy into their own schema).

datasource db {
  provider = "sqlite"
  url      = "file:./test.db"
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

model DurableWorkflowRun {
  id              String   @id
  workflow        String
  workflowVersion String
  status          String
  input           Json?
  output          Json?
  error           Json?
  wakeAt          BigInt?
  lockedBy        String?
  lockedUntil     DateTime?
  createdAt       DateTime
  updatedAt       DateTime

  @@index([status, wakeAt])
  @@map("durable_workflow_runs")
}

model DurableStepCheckpoint {
  runId       String
  seq         Int
  name        String
  kind        String
  stepId      String
  status      String
  output      Json?
  error       Json?
  attempts    Int
  workerGroup String?
  wakeAt      BigInt?
  startedAt   DateTime
  finishedAt  DateTime

  @@id([runId, seq])
  @@map("durable_step_checkpoints")
}

model DurableSignalWaiter {
  token String @id
  runId String
  seq   Int

  @@map("durable_signal_waiters")
}
