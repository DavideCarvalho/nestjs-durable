  "description": "Testing utilities for nestjs-durable — a test engine harness, crash/flaky-step injection, and replay assertions",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/testing"
  },
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
