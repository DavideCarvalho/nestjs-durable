      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "typescript": "5.9.3",
    "vitest": "2.1.9",
    "tsup": "8.3.5"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
