{
  "name": "@dudousxd/nestjs-durable-transport-bullmq",
  "version": "0.12.0",
  "description": "BullMQ (Redis) Transport for nestjs-durable — cross-process and cross-language steps",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/transport-bullmq"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/durable-worker": ">=0.1.0 <1.0.0",
    "@dudousxd/nestjs-durable-core": ">=0.1.0 <1.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0"
  },
  "devDependencies": {
    "@dudousxd/durable-worker": "workspace:^",
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "@testcontainers/redis": "10.18.0",
    "bullmq": "5.34.10",
    "ioredis": "5.4.2",
    "typescript": "5.9.3",
    "zod": "3.25.76",
    "tsup": "8.3.5"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
