{
  "name": "@dudousxd/nestjs-durable-transport-sqs",
  "version": "0.1.0",
  "description": "Amazon SQS Transport for nestjs-durable — dispatch remote steps over existing SQS queues (ElasticMQ-compatible)",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/transport-sqs"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@aws-sdk/client-sqs": "^3.0.0",
    "@dudousxd/nestjs-durable-core": ">=0.1.0 <1.0.0"
  },
  "devDependencies": {
    "@aws-sdk/client-sqs": "3.1034.0",
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "testcontainers": "10.28.0",
    "typescript": "5.9.3",
    "zod": "3.25.76",
    "tsup": "8.3.5"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
