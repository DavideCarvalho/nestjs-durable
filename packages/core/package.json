{
  "name": "@dudousxd/nestjs-durable-core",
  "version": "0.35.0",
  "description": "Durable workflows for NestJS — core interfaces, engine and deterministic replay",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/core"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "cron-parser": "^4.0.0 || ^5.0.0",
    "reflect-metadata": "^0.2.0",
    "zod": "^3.0.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "cron-parser": {
      "optional": true
    }
  },
  "devDependencies": {
    "cron-parser": "4.9.0",
    "reflect-metadata": "0.2.2",
    "tsup": "8.3.5",
    "typescript": "5.9.3",
    "zod": "3.25.76",
    "@dudousxd/nestjs-diagnostics": "^0.5.0"
  }
}
