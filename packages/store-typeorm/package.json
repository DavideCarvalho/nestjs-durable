{
  "name": "@dudousxd/nestjs-durable-store-typeorm",
  "version": "0.11.0",
  "description": "TypeORM adapter for the nestjs-durable StateStore",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/store-typeorm"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-durable-core": ">=0.1.0 <1.0.0",
    "typeorm": "^0.3.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "@dudousxd/nestjs-durable-testing": "workspace:^",
    "@testcontainers/mysql": "10.18.0",
    "@testcontainers/postgresql": "10.18.0",
    "better-sqlite3": "11.10.0",
    "mysql2": "3.11.5",
    "pg": "8.13.1",
    "reflect-metadata": "0.2.2",
    "typeorm": "0.3.30",
    "typescript": "5.9.3",
    "tsup": "8.3.5"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
