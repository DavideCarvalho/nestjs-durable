{
  "name": "@dudousxd/durable-worker",
  "version": "0.3.4",
  "description": "Thin, store-free Node durable worker — replays @Workflow bodies (history → commands) symmetric with the Python durable-worker",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/worker"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-durable-core": ">=0.1.0 <1.0.0",
    "bullmq": "^5.0.0",
    "ioredis": "^5.0.0"
  },
  "peerDependenciesMeta": {
    "bullmq": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    }
  },
  "devDependencies": {
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "bullmq": "5.34.10",
    "ioredis": "5.4.2",
    "typescript": "5.9.3",
    "vitest": "2.1.9",
    "tsup": "8.3.5"
  }
}
