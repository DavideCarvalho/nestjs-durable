{
  "name": "@dudousxd/nestjs-durable-telescope",
  "version": "0.6.2",
  "description": "Telescope watcher for nestjs-durable — workflow runs and steps as Telescope entries",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/telescope"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-durable-core": ">=0.1.0 <1.0.0",
    "@dudousxd/nestjs-telescope": ">=1.0.0 <2.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "@opentelemetry/api": "^1.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "@dudousxd/nestjs-telescope": "1.10.0",
    "@nestjs/core": "11.1.26",
    "@opentelemetry/api": "1.9.0",
    "typescript": "5.9.3",
    "tsup": "8.3.5"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
