{
  "name": "@dudousxd/nestjs-durable-store-mikro-orm",
  "version": "0.8.0",
  "description": "MikroORM adapter for the nestjs-durable StateStore (reference ORM adapter)",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/store-mikro-orm"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-durable-core": ">=0.1.0 <1.0.0",
    "@mikro-orm/core": "^6.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "@dudousxd/nestjs-durable-testing": "workspace:^",
    "@mikro-orm/better-sqlite": "6.6.2",
    "@mikro-orm/core": "6.6.2",
    "@mikro-orm/mysql": "6.6.2",
    "@mikro-orm/postgresql": "6.6.2",
    "@testcontainers/mysql": "10.18.0",
    "@testcontainers/postgresql": "10.18.0",
    "reflect-metadata": "0.2.2",
    "typescript": "5.9.3",
    "tsup": "8.3.5"
  },
  "module": "./dist/index.js",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  }
}
