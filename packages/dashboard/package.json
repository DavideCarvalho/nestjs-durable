{
  "name": "@dudousxd/nestjs-durable-dashboard",
  "version": "1.0.0",
  "description": "Embedded control plane (runs, step timeline, retry/cancel) for nestjs-durable — bundled React SPA served by NestJS",
  "license": "MIT",
  "author": "Davide Carvalho",
  "repository": {
    "type": "git",
    "url": "https://github.com/DavideCarvalho/nestjs-durable.git",
    "directory": "packages/dashboard"
  },
  "type": "module",
  "main": "./dist/server/index.js",
  "types": "./dist/server/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/server/index.d.ts",
      "import": "./dist/server/index.js",
      "default": "./dist/server/index.js"
    },
    "./client": {
      "types": "./dist/client/durable-client.d.ts",
      "import": "./dist/client/durable-client.js",
      "default": "./dist/client/durable-client.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "vite build && tsc -p tsconfig.server.json && tsc -p tsconfig.client.json",
    "typecheck": "tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.app.json --noEmit"
  },
  "peerDependencies": {
    "@dudousxd/nestjs-durable-core": ">=1.0.0",
    "@nestjs/common": "^10.0.0 || ^11.0.0",
    "@nestjs/core": "^10.0.0 || ^11.0.0",
    "rxjs": "^7.0.0"
  },
  "devDependencies": {
    "@dudousxd/nestjs-durable-core": "workspace:^",
    "@nestjs/common": "11.1.26",
    "@nestjs/core": "11.1.26",
    "@tanstack/react-query": "5.62.7",
    "@xyflow/react": "12.3.6",
    "@types/react": "18.3.18",
    "@types/react-dom": "18.3.5",
    "@vitejs/plugin-react": "4.3.4",
    "autoprefixer": "10.4.20",
    "postcss": "8.4.49",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "reflect-metadata": "0.2.2",
    "tailwindcss": "3.4.17",
    "typescript": "5.9.3",
    "vite": "5.4.21"
  }
}
